{
  "name": "history-academy",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev:api": "pnpm --filter @history-academy/api dev",
    "dev:mobile": "pnpm --filter @history-academy/mobile start"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0"
  }
}
